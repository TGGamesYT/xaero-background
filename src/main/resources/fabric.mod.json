{
  "schemaVersion": 1,
  "id": "xaerobackground",
  "version": "${version}",
  "name": "xaerobackground",
  "description": "a mod to change texture/resourcepacks automatically",
  "authors": [],
  "contact": {},
  "license": "MIT",
  "icon": "assets/xaerobackground/icon.png",
  "environment": "*",
  "entrypoints": {
    "fabric-datagen": [
      "me.tg.xaerobackground.client.XaerobackgroundDataGenerator"
    ],
    "client": [
      "me.tg.xaerobackground.client.XaerobackgroundClient"
    ],
    "main": [
      "me.tg.xaerobackground.Xaerobackground"
    ]
  },
  "mixins": [
    "xaerobackground.mixins.json",
    {
      "config": "xaerobackground.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric": "*",
    "minecraft": "${minecraft_version}"
  }
}
